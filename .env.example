# ──────────────────────────────────────────────
# SignalSniper-AI Environment Variables
# ──────────────────────────────────────────────

# Required: Fireworks AI API key for signal analysis
# Get one at https://fireworks.ai
FIREWORKS_API_KEY=

# Optional: Gemma AI endpoint (vLLM server)
# Leave empty for mock mode (realistic sample responses)
# Set to your vLLM/Gemma GPU server for real inference
# Example: http://gpu-server:8000/v1/chat/completions
GEMMA_API_URL=
